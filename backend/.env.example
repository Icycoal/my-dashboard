# Copy to .env and fill in your own values. Never commit .env.

# JWT signing key (use a long random string, e.g. `openssl rand -hex 32`)
HEALTH_JWT_SECRET=

# Registration — set to true only when creating your account, then remove
ALLOW_REGISTER=true

# Plaid credentials (https://dashboard.plaid.com/developers/keys)
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# Optional: path to the IBKR Client Portal Gateway
# (defaults to ~/Downloads/clientportal.gw)
# IBKR_GATEWAY_PATH=
